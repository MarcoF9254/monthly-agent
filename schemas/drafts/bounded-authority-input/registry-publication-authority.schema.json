{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/monthly-agent/schemas/drafts/bounded-authority-input/registry-publication-authority.schema.json",
  "title": "Registry Publication Authority Draft 0.1",
  "description": "Inactive, non-production draft external authority binding for one canonical registry snapshot authorization subject.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "authority_id", "authority_purpose", "authorized_subject_type", "authorized_subject_sha256", "registry_id", "snapshot_id", "scope", "owner_authority", "decision_reference", "issued_at"],
  "properties": {
    "contract_version": {"const": "registry-publication-authority/0.1.0-draft"},
    "authority_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"},
    "authority_purpose": {"const": "calendar-registry-publication"},
    "authorized_subject_type": {"const": "calendar-registry-snapshot-publication"},
    "authorized_subject_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "registry_id": {"type": "string", "minLength": 1},
    "snapshot_id": {"type": "string", "minLength": 1},
    "scope": {"$ref": "#/$defs/scope"},
    "owner_authority": {"type": "string", "minLength": 1},
    "decision_reference": {"type": "string", "minLength": 1},
    "issued_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "consumer_id", "programme_month", "registry_purpose"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "consumer_id": {"const": "calendar-renderer"},
        "programme_month": {"type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"},
        "registry_purpose": {"const": "calendar-authority-resolution"}
      }
    }
  }
}
