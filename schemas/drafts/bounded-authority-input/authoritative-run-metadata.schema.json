{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/monthly-agent/schemas/drafts/bounded-authority-input/authoritative-run-metadata.schema.json",
  "title": "Authoritative Run Metadata Binding Draft 0.1",
  "description": "Inactive, non-production draft binding of an opaque run_id to programme_month. Real metadata authority remains unresolved.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "metadata_id", "run_id", "programme_month", "consumer_id", "binding_status", "source_authority"],
  "properties": {
    "contract_version": {"const": "authoritative-run-metadata/0.1.0-draft"},
    "metadata_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"},
    "run_id": {"type": "string", "minLength": 1},
    "programme_month": {"type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"},
    "consumer_id": {"const": "calendar-renderer"},
    "binding_status": {"const": "fictional-draft-binding"},
    "source_authority": {"const": "fictional-owner-example"}
  }
}
