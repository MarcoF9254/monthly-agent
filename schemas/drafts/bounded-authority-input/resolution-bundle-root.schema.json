{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/monthly-agent/schemas/drafts/bounded-authority-input/resolution-bundle-root.schema.json",
  "title": "Verified Resolution Bundle Root Draft 0.2",
  "description": "Inactive complete OAR bundle root. Trust anchor remains externally supplied and outside the inventory.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "bundle_id", "input_mode", "scope", "registry_id", "snapshot_id", "snapshot_artifact_sha256", "builder_version", "artifact_inventory"],
  "properties": {
    "contract_version": {"const": "resolution-bundle-root/0.2.0-draft"},
    "bundle_id": {"type": "string", "pattern": "^bundle_sha256_[0-9a-f]{64}$"},
    "input_mode": {"const": "verified-resolution-bundle"},
    "scope": {"$ref": "https://example.local/monthly-agent/schemas/drafts/bounded-authority-input/authority-registry-snapshot.schema.json#/$defs/scope"},
    "registry_id": {"type": "string", "minLength": 1},
    "snapshot_id": {"type": "string", "minLength": 1},
    "snapshot_artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "builder_version": {"type": "string", "minLength": 1},
    "artifact_inventory": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/item"}}
  },
  "$defs": {
    "item": {"type": "object", "additionalProperties": false, "required": ["artifact_type", "logical_id", "artifact_path", "artifact_sha256"], "properties": {"artifact_type": {"enum": ["authority-envelope", "authority-revocation-subject", "calendar-eligibility-subject", "calendar-monthly-selection-subject", "registry-publication-envelope", "registry-publication-subject", "registry-snapshot", "run-metadata-binding-subject"]}, "logical_id": {"type": "string", "minLength": 1}, "artifact_path": {"type": "string", "pattern": "^[A-Za-z0-9._/-]+[.]json$"}, "artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}}
  }
}
