{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/monthly-agent/schemas/drafts/owner-authority-resolution/authority-revocation-subject.schema.json",
  "title": "Authority Revocation Subject Draft 0.1",
  "description": "Inactive subject-only exact revocation target. Filename and schema validity confer no authority.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "subject_id", "subject_version", "supersedes_subject_id", "supersedes_subject_sha256", "target_authority_id", "target_authority_artifact_sha256", "target_authority_purpose", "target_subject_type", "target_subject_id", "target_subject_sha256", "target_scope", "reason_code"],
  "properties": {
    "contract_version": {"const": "authority-revocation-subject/0.1.0-draft"},
    "subject_id": {"type": "string", "minLength": 1},
    "subject_version": {"const": 1},
    "supersedes_subject_id": {"const": null},
    "supersedes_subject_sha256": {"const": null},
    "target_authority_id": {"type": "string", "minLength": 1},
    "target_authority_artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "target_authority_purpose": {"enum": ["calendar-eligibility", "calendar-monthly-selection", "calendar-registry-publication", "run-metadata-binding", "calendar-authority-revocation"]},
    "target_subject_type": {"enum": ["calendar-eligibility", "calendar-monthly-selection", "calendar-registry-publication", "run-metadata-binding", "calendar-authority-revocation"]},
    "target_subject_id": {"type": "string", "minLength": 1},
    "target_subject_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "target_scope": {"$ref": "https://example.local/monthly-agent/schemas/drafts/owner-authority-resolution/authority-envelope.schema.json#/$defs/scope"},
    "reason_code": {"type": "string", "pattern": "^[a-z][a-z0-9.-]{2,63}$"}
  }
}
