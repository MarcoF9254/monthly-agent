{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/monthly-agent/schemas/drafts/owner-authority-resolution/calendar-eligibility-subject.schema.json",
  "title": "Calendar Eligibility Subject Draft 0.3",
  "description": "Inactive subject-only business artifact; contains no authority metadata or embedded digest.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "subject_id", "subject_version", "supersedes_subject_id", "supersedes_subject_sha256", "run_id", "activity_id", "consumer_id", "decision", "allowed_fields", "prohibited_uses"],
  "properties": {
    "contract_version": {"const": "calendar-eligibility-subject/0.3.0-draft"},
    "subject_id": {"type": "string", "minLength": 1},
    "subject_version": {"type": "integer", "minimum": 1},
    "supersedes_subject_id": {"type": ["string", "null"]},
    "supersedes_subject_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "run_id": {"type": "string", "minLength": 1},
    "activity_id": {"type": "string", "minLength": 1},
    "consumer_id": {"const": "calendar-renderer"},
    "decision": {"enum": ["eligible", "denied"]},
    "allowed_fields": {"type": "array", "items": {"enum": ["activity_id", "activity_title", "dates", "time"]}},
    "prohibited_uses": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "allOf": [
    {"if": {"properties": {"subject_version": {"const": 1}}}, "then": {"properties": {"supersedes_subject_id": {"const": null}, "supersedes_subject_sha256": {"const": null}}}, "else": {"properties": {"supersedes_subject_id": {"type": "string"}, "supersedes_subject_sha256": {"type": "string"}}}},
    {"if": {"properties": {"decision": {"const": "eligible"}}}, "then": {"properties": {"allowed_fields": {"prefixItems": [{"const": "activity_id"}, {"const": "activity_title"}, {"const": "dates"}, {"const": "time"}], "items": false, "minItems": 4, "maxItems": 4}}}, "else": {"properties": {"allowed_fields": {"maxItems": 0}}}}
  ]
}
