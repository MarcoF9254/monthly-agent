{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/monthly-agent/schemas/drafts/owner-authority-resolution/registry-publication-subject.schema.json",
  "title": "Registry Publication Subject Draft 0.1",
  "description": "Inactive standalone canonical snapshot-core subject for the non-self-authorizing publication bootstrap.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "subject_id", "snapshot_contract_version", "registry_id", "snapshot_id", "snapshot_version", "supersedes_snapshot_id", "supersedes_snapshot_artifact_sha256", "scope", "entries"],
  "properties": {
    "contract_version": {"const": "registry-publication-subject/0.1.0-draft"},
    "subject_id": {"type": "string", "minLength": 1},
    "snapshot_contract_version": {"const": "authority-registry-snapshot/0.2.0-draft"},
    "registry_id": {"type": "string", "minLength": 1},
    "snapshot_id": {"type": "string", "minLength": 1},
    "snapshot_version": {"type": "integer", "minimum": 1},
    "supersedes_snapshot_id": {"type": ["string", "null"]},
    "supersedes_snapshot_artifact_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "scope": {"$ref": "#/$defs/scope"},
    "entries": {"type": "array", "items": {"$ref": "#/$defs/entry"}}
  },
  "$defs": {
    "scope": {"type": "object", "additionalProperties": false, "required": ["run_id", "consumer_id", "programme_month", "registry_purpose"], "properties": {"run_id": {"type": "string", "minLength": 1}, "consumer_id": {"const": "calendar-renderer"}, "programme_month": {"type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"}, "registry_purpose": {"const": "calendar-authority-resolution"}}},
    "entry": {"type": "object", "additionalProperties": false, "required": ["subject_type", "subject_id", "subject_sha256", "authority_id", "authority_purpose", "authority_artifact_sha256", "authority_status"], "properties": {"subject_type": {"enum": ["calendar-eligibility", "calendar-monthly-selection", "run-metadata-binding", "calendar-authority-revocation"]}, "subject_id": {"type": "string", "minLength": 1}, "subject_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "authority_id": {"type": "string", "minLength": 1}, "authority_purpose": {"enum": ["calendar-eligibility", "calendar-monthly-selection", "run-metadata-binding", "calendar-authority-revocation"]}, "authority_artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "authority_status": {"enum": ["accepted", "revoked"]}}}
  }
}
