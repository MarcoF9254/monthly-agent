{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/monthly-agent/schemas/drafts/calendar-only/scoped-eligibility-decision.schema.json",
  "title": "Scoped Consumer Eligibility Decision Draft 0.2",
  "description": "Draft, non-active contract for one immutable consumer eligibility decision with exact authorization-subject binding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "decision_id",
    "decision_version",
    "supersedes_decision_id",
    "run_id",
    "activity_id",
    "consumer_id",
    "decision",
    "allowed_fields",
    "prohibited_uses",
    "eligibility_subject_sha256",
    "authority_purpose",
    "authority_reference",
    "authority_artifact_sha256",
    "decided_at"
  ],
  "properties": {
    "contract_version": {
      "const": "scoped-consumer-eligibility/0.2.0-draft"
    },
    "decision_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"
    },
    "decision_version": {
      "type": "integer",
      "minimum": 1
    },
    "supersedes_decision_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-r[0-9]{2}$"
    },
    "activity_id": {
      "type": "string",
      "minLength": 1
    },
    "consumer_id": {
      "const": "calendar-renderer"
    },
    "decision": {
      "enum": [
        "eligible",
        "denied"
      ]
    },
    "allowed_fields": {
      "type": "array",
      "description": "Calendar-renderer eligible decisions require the exact four source fields in canonical order; denied decisions contain none.",
      "items": {
        "enum": ["activity_id", "activity_title", "dates", "time"]
      }
    },
    "prohibited_uses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "eligibility_subject_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "authority_purpose": {
      "const": "calendar-eligibility"
    },
    "authority_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_id",
        "authority_id"
      ],
      "properties": {
        "registry_id": {
          "type": "string",
          "minLength": 1
        },
        "authority_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "authority_artifact_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "eligible"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "allowed_fields": {
            "prefixItems": [
              { "const": "activity_id" },
              { "const": "activity_title" },
              { "const": "dates" },
              { "const": "time" }
            ],
            "items": false,
            "minItems": 4,
            "maxItems": 4
          }
        }
      },
      "else": {
        "properties": {
          "allowed_fields": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
