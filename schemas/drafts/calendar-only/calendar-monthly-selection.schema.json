{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/monthly-agent/schemas/drafts/calendar-only/calendar-monthly-selection.schema.json",
  "title": "Calendar Monthly Selection Decision Draft 0.2",
  "description": "Draft, non-active immutable monthly publication-selection decision. Subject hashing, ordering, resolution, and external verification are semantic requirements.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "selection_id", "selection_version", "supersedes_selection_id", "run_id", "consumer_id", "programme_month", "selected_activity_ids", "selection_subject_sha256", "authority_purpose", "owner_authority", "decision_reference", "authority_artifact_sha256", "decided_at"],
  "properties": {
    "contract_version": { "const": "calendar-monthly-selection/0.2.0-draft" },
    "selection_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$" },
    "selection_version": { "type": "integer", "minimum": 1 },
    "supersedes_selection_id": { "type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$" },
    "run_id": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-r[0-9]{2}$" },
    "consumer_id": { "const": "calendar-renderer" },
    "programme_month": { "type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$" },
    "selected_activity_ids": {
      "type": "array",
      "description": "Unique and lexicographically sorted by Unicode code-point order; empty means an explicit authorized empty set.",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "selection_subject_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "authority_purpose": { "const": "calendar-monthly-selection" },
    "owner_authority": { "type": "string", "minLength": 1 },
    "decision_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry_id", "authority_id"],
      "properties": {
        "registry_id": { "type": "string", "minLength": 1 },
        "authority_id": { "type": "string", "minLength": 1 }
      }
    },
    "authority_artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "decided_at": { "type": "string", "format": "date-time" }
  }
}
