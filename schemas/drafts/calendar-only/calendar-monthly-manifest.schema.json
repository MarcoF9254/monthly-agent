{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/monthly-agent/schemas/drafts/calendar-only/calendar-monthly-manifest.schema.json",
  "title": "Calendar Monthly Manifest Draft 0.1",
  "description": "Draft, non-active manifest binding the complete ordered per-activity projection set for one run and month.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "manifest_id",
    "selection_id",
    "selection_artifact_sha256",
    "builder_version",
    "consumer_id",
    "run_id",
    "programme_month",
    "entries"
  ],
  "properties": {
    "contract_version": {
      "const": "calendar-monthly-manifest/0.1.0-draft"
    },
    "manifest_id": {
      "type": "string",
      "pattern": "^calmanifest_sha256_[0-9a-f]{64}$"
    },
    "selection_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$" },
    "selection_artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "builder_version": { "type": "string", "minLength": 1 },
    "consumer_id": {
      "const": "calendar-renderer"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-r[0-9]{2}$"
    },
    "programme_month": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
    },
    "entries": {
      "type": "array",
      "description": "Complete effective selection, sorted lexicographically by activity_id. Empty only for an explicit effective empty selection.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "activity_id",
          "projection_id",
          "payload_sha256"
        ],
        "properties": {
          "activity_id": {
            "type": "string",
            "minLength": 1
          },
          "projection_id": {
            "type": "string",
            "pattern": "^calproj_sha256_[0-9a-f]{64}$"
          },
          "payload_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
