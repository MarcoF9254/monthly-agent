{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MarcoF9254/monthly-agent/schemas/governance-post-merge-gate-input.schema.json",
  "title": "Governance post-merge gate input",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "repository", "merge_commit", "expected_base", "expected_reviewed_head", "expected_landed_paths", "main_ref"],
  "properties": {
    "version": {"const": 1},
    "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
    "merge_commit": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "expected_base": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "expected_reviewed_head": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "expected_landed_paths": {
      "type": "array", "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?![A-Za-z]:)(?!\\.$)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*\\\\).+$"}
    },
    "main_ref": {"type": "string", "minLength": 1}
  }
}
