      "expected_rejection_stage": "publication-bootstrap",
      "expected_semantic_reason": "oar-bs-001",
      "earlier_layers_remain_valid_because": "Inserted entry is schema-valid and enclosing digests are rebuilt; exact publication envelope ID/digest is visible in ordinary membership."
    },
