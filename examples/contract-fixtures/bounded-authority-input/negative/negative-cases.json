{
  "contract_version": "oar-negative-corpus/0.2.0-draft",
  "scenarios": {
    "pre-revocation": "../../owner-authority-resolution/positive/pre-revocation",
    "post-revocation": "../../owner-authority-resolution/positive/post-revocation"
  },
  "mutation_operation_vocabulary": [
    "add_artifact",
    "duplicate_artifact",
    "remove_artifact",
    "reorder_array",
    "replace_value"
  ],
  "mutation_semantics": {
    "operations_are_ordered": true,
    "pointers": "RFC 6901 JSON Pointers; /- appends to an array",
    "virtual_artifacts": "add_artifact may derive an in-memory artifact from template_artifact_path plus overrides; it creates no repository file",
    "cascade": "When recompute_dependents is present, recompute the named RFC 8785/SHA-256 bindings in listed order. No unlisted binding changes.",
    "bundle_repair": "remove_bundle_declaration removes the matching inventory item; rebuild_bundle recomputes physical hashes, canonical order, and bundle_id.",
    "scenario_context": "The symbolic path $resolution-context is validation context, not a repository artifact."
  },
  "cases": [
    {
      "fixture_id": "OAR-N01",
      "title": "Missing external trust anchor",
      "base_fixture": "pre-revocation",
      "source_scenario": "pre-revocation",
      "mutation": {
        "ordered_operations": [
          {
            "operation": "remove_artifact",
            "artifact_path": "trust-anchor.json"
          }
        ]
      },
      "expected_first_failure_layer": "production-admission",
      "expected_rule_id": "BAI-TA-001",
      "expected_primary_component": "Operational caller",
      "expected_rejection_stage": "production-admission",
      "expected_semantic_reason": "bai-ta-001",
      "earlier_layers_remain_valid_because": "Bundle and contained artifacts are unchanged; admission fails first."
    },
    {
